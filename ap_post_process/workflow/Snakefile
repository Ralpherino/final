rule all:
    input:
        all_targets

# Run the PIDGen package
# produces one file for each variable produced by the PIDGen package
# for each input file
# -------------------------------------------------------------------
rule pidgen:
    input:
        get_pfn_for_guid,
    output:
        [
            f"{tempdir}/pidgen_{{datatype}}_{{eventtype}}_{{polarity}}_{{sign}}_{{guid}}_{{track}}_{{var}}.root"
        ],
    log:
        "logs/pidgen_{datatype}_{eventtype}_{polarity}_{sign}_{guid}_{track}_{var}.log",
    shell:
        "lb-conda pidgen/2023-05-05 python workflow/scripts/pidgen2_rds_hadronic.py {tempdir} {wildcards.datatype} {wildcards.eventtype} {wildcards.polarity} {wildcards.sign} {wildcards.track} {wildcards.var} {input} 2>&1 >{log}"


# Gathers the branches with PID info into one single ROOT file
# per input ROOT file (identified by its GUID).
# This ROOT file can be used by making it a friend of the initial
# ntuple
# -------------------------------------------------------------------
def merge_friends_input(w):
    ptype, columns = pidgen_type(w.eventtype)
    tmp = [
        f"{tempdir}/pidgen_{w.datatype}_{w.eventtype}_{w.polarity}_{w.sign}_{w.guid}_{c}.root"
        for c in columns
    ]
    return tmp


rule merge_friends:
    input:
        merge_friends_input,
    output:
        r(f"{outdir}/mergedpidgen_{{datatype}}_{{eventtype}}_{{polarity}}_{{sign}}_{{guid}}.root"),
    log:
        "logs/merge_friends_{datatype}_{eventtype}_{polarity}_{sign}_{guid}.log",
    shell:
        "workflow/scripts/merge_friends.py {output} {input} >{log} 2>&1"


# Create a file with the configuration of the TChain needed to read the data
# --------------------------------------------------------------------------
def ntuple_config_input(w):
    return [
        r(f"{outdir}/mergedpidgen_{w.datatype}_{w.eventtype}_{w.polarity}_{w.sign}_{g}.root")
        for g in list_guids(w)
    ]


rule ntuple_config:
    input:
        pidinfo=ntuple_config_input,
        pfns=list_pfns,
    output:
        r(f"{outdir}/pidinfo_{{datatype}}_{{eventtype}}_{{polarity}}_{{sign}}.json"),
    run:
        data = {}
        data["datatype"] = str(wildcards.datatype)
        data["eventtype"] = str(wildcards.eventtype)
        data["polarity"] = str(wildcards.polarity)
        data["sign"] = str(wildcards.sign)
        data["pfns"] = [str(s) for s in input.pfns]
        data["guids"] = {str(p): get_guid(p) for p in input.pfns}
        data["pidinfo"] = [str(s) for s in input.pidinfo]
        import json

        with open(str(output), "w") as f:
            json.dump(data, f)


# Apply the BDT and filter a specific file (with that initial file
# and the PID information file generate in rules above).
# --------------------------------------------------------------------------
rule filter_file_noBYsep:
    input:
        scripts=[ "workflow/scripts/RDsProcess.C", "workflow/scripts/BsSignalCUT.h", 
                "workflow/scripts/LEAF_BranchAddress.h", "workflow/scripts/LEAF_definition.h"],
        pfn=get_pfn_for_guid,
        pidinfo=r(f"{outdir}/mergedpidgen_{{datatype}}_{{eventtype}}_{{polarity}}_{{sign}}_{{guid}}.root"),
    output:
        [
            r(f"{outdir}/rds_filterednoBYsep_{{datatype}}_{{eventtype}}_{{polarity}}_{{sign}}_{{guid}}.root")
        ],
    log:
        "logs/rds_filterednoBYsep_{datatype}_{eventtype}_{polarity}_{sign}_{guid}.log",
    shell:
        'cd workflow/scripts && root -q \'RDsProcess_noBYsep.C("{input.pfn}", "{input.pidinfo}", "{output}", "{wildcards.eventtype}")\' 2>&1 >../../{log}'


# Merge filtered data into one single ntuple per dataset
# --------------------------------------------------------------------------
def merge_all_input_noBYsep(w):
    return [
        r(f"{outdir}/rds_filterednoBYsep_{w.datatype}_{w.eventtype}_{w.polarity}_{w.sign}_{g}.root")
        for g in list_guids(w)
    ]


rule merge_all_noBYsep:
    input:
        filtered=merge_all_input_noBYsep,
    output:
        r(f"{outdir}/rds_finalnoBYsep_{{datatype}}_{{eventtype}}_{{polarity}}_{{sign}}.root"),
    log:
        "logs/rds_finalnoBYsep_{datatype}_{eventtype}_{polarity}_{sign}.log",
    shell:
        "python workflow/scripts/merge_trees.py {output} {input} >{log} 2>&1"



# Apply the BDT and filter a specific file (with that initial file
# and the PID information file generate in rules above).
# --------------------------------------------------------------------------
rule filter_file:
    input:
        scripts=[ "workflow/scripts/RDsProcess.C", "workflow/scripts/BsSignalCUT.h", 
                "workflow/scripts/LEAF_BranchAddress.h", "workflow/scripts/LEAF_definition.h"],
        pfn=get_pfn_for_guid,
        pidinfo=r(f"{outdir}/mergedpidgen_{{datatype}}_{{eventtype}}_{{polarity}}_{{sign}}_{{guid}}.root"),
    output:
        [
            r(f"{outdir}/rds_filtered_{{datatype}}_{{eventtype}}_{{polarity}}_{{sign}}_{{guid}}.root")
        ],
    log:
        "logs/rds_filtered_{datatype}_{eventtype}_{polarity}_{sign}_{guid}.log",
    shell:
        'cd workflow/scripts && root -q \'RDsProcess.C("{input.pfn}", "{input.pidinfo}", "{output}", "{wildcards.eventtype}")\' 2>&1 >../../{log}'


# Merge filtered data into one single ntuple per dataset
# --------------------------------------------------------------------------
def merge_all_input(w):
    return [
        r(f"{outdir}/rds_filtered_{w.datatype}_{w.eventtype}_{w.polarity}_{w.sign}_{g}.root")
        for g in list_guids(w)
    ]


rule merge_all:
    input:
        filtered=merge_all_input,
    output:
        r(f"{outdir}/rds_final_{{datatype}}_{{eventtype}}_{{polarity}}_{{sign}}.root"),
    log:
        "logs/rds_final_{datatype}_{eventtype}_{polarity}_{sign}.log",
    shell:
        "python workflow/scripts/merge_trees.py {output} {input} >{log} 2>&1"



# Rule to classify the background categories in the Inclusive MC sample
# --------------------------------------------------------------------------
rule classify_background:
    input:
        script="workflow/scripts/add_categorization.py",
        data=r(f"{outdir}/rds_final_{{datatype}}_{{eventtype}}_{{polarity}}_{{sign}}.root"),
    output:
        data=r(f"{outdir}/rds_categ_{{datatype}}_{{eventtype}}_{{polarity}}_{{sign}}.root"),
        metadata=l(f"{outdir}/rds_categ_metadata_{{datatype}}_{{eventtype}}_{{polarity}}_{{sign}}.json"),
    log:
        "logs/rds_categ_{datatype}_{eventtype}_{polarity}_{sign}.log",
    shell:
        "python {input.script} {input.data} {output.data} {output.metadata} >{log} 2>&1"


# Rule to classify the background categories in the Inclusive MC sample
# --------------------------------------------------------------------------
rule split_by_bkg_category:
    input:
        script="workflow/scripts/split_by_bkg_category.py",
        data=r(f"{outdir}/rds_categ_{{datatype}}_{{eventtype}}_{{polarity}}_{{sign}}.root"),
    output:
        r(f"{outdir}/rds_categfiltered_{{datatype}}_{{eventtype}}_{{polarity}}_{{sign}}_{{categ}}.root"),
    log:
        "logs/rds_categfiltered_{datatype}_{eventtype}_{polarity}_{sign}_{categ}.log",
    shell:
        "python workflow/scripts/split_by_bkg_category.py {input.data} {output} {wildcards.categ} >{log} 2>&1"


# Filter data to check normalization peak
# --------------------------------------------------------------------------
rule filter_by_BMsup5000:
    input:
        r(f"{outdir}/rds_finalnoBYsep_{{datatype}}_{{eventtype}}_{{polarity}}_{{sign}}.root"),
    output:
        r(f"{outdir}/rds_finalBMsup5000_{{datatype}}_{{eventtype}}_{{polarity}}_{{sign}}.root"),
    log:
        "logs/rds_finalBMsup5000_{datatype}_{eventtype}_{polarity}_{sign}.log",
    shell:
        "python workflow/scripts/filter_by_BMsup5000.py {input} {output}>{log} 2>&1"

