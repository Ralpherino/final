#
# Workflow that processes the Hadronic R(Ds) analysis production and
# and add the PID information using the pidgen2 package.
# It then applies the R(Ds) hadronic BDts and filters the data.
#

from snakemake.utils import min_version

min_version("6.0")


include: "common/rds.snk"

configfile: "config/config.json"


# Looking up the temporary and target directory from the config
tempdir = config["TEMP_DIR"]
outdir = config["OUTPUT_DIR"]


# Constants used to defined targets to be produced
##################################################

# eventtypes for which there is no right sign/wrong sign samples
eventtypes = [ "13763200", "13266069", "13863401", "11266009"]

# Inclusive MC event types
eventtypes_inclMC = [ "23903003", "23903000",]

# Inclusive MC event types
eventtypes_signal = [ "13563002", ]

# eventtypes for which we have right sign/wrong sign samples
eventtypes_sign = eventtypes_signal + eventtypes_inclMC

# other attributes of the dataset
polarities = ["magup", "magdown"]
datatypes = ["2012"]
signs = ["ws", "rs"]
tracks = [f"p{i}_from{e}" for i in range(1, 4) for e in ["Xc", "Y"]]
vars = ["PIDK", "PIDp", "pi_PIDK", "K_PIDK"]


# Utility functions
##############################################

# There are two different types of columns
pidgen_default_columns = [
    f"p{i}_from{e}_PID{p}" for i in range(1, 4) for e in ["Xc", "Y"] for p in ["K", "p"]
]

pidgen_inclmc_columns = [
    f"p{i}_fromXc_PID{p}" for i in range(1, 4) for p in ["K", "p"]
] + [f"p{i}_fromY_{e}_PIDK" for i in range(1, 4) for e in ["pi", "K"]]


def pidgen_type(eventtype):
    """return the list of files names that will be created by the pidgen script"""
    if eventtype in ["23903000", "23903003"]:
        return ("inclmc", pidgen_inclmc_columns)
    else:
        return ("default", pidgen_default_columns)


# processing rules
##############################################
wildcard_constraints:
    datatype="\d{4}",
    eventtype="\d{8}",
    polarity="(magup|magdown)",
    sign="(ws|rs|None)",
    track=f"({'|'.join(tracks)})",
    var=f"({'|'.join(vars)})",

# Main rule that requires the final filtered
# files with the BDT.
##############################################
def all_targets(w):
        all_targets = []
        # Inclusive MC Filtered ntuple with categorization, one file per category
        # The categorization is:
        # "18": "Xc_signal_Ypis_displaced_fromBs_fromDs",
        # "19": "Xc_signal_Ypis_displaced_fromB0_fromDp",
        # "20": "Xc_signal_Ypis_displaced_fromBp_fromD0",
        # "29": "Xc_signal_Ypis_displaced_fromBs_fromDs_fromTau",
        all_targets += [ r(f) for f in 
            expand(
                f"{outdir}/rds_categfiltered_{{d}}_{{e}}_{{p}}_{{s}}_{{categs}}.root",
                d=datatypes,
                e=eventtypes_inclMC,
                p=polarities,
                s=signs,
                categs=[18, 19, 20, 29]
            )]
        # Signal sample ntuple with categorization, one file per category
        # "24": "Xc_signal_Ypis_displaced_fromBs_fromTau",
        all_targets += [ r(f) for f in 
            expand(
                f"{outdir}/rds_categfiltered_{{d}}_{{e}}_{{p}}_{{s}}_{{categs}}.root",
                d=datatypes,
                e=eventtypes_signal,
                p=polarities,
                s=signs,
                categs=[24]
            )]
        # ntuples with categorization and associated metadata
        # for samples with RS/WS
        all_targets += [ r(f) for f in 
            expand(
                f"{outdir}/rds_categ_{{d}}_{{e}}_{{p}}_{{s}}.root",
                d=datatypes,
                e=eventtypes_inclMC + eventtypes_signal,
                p=polarities,
                s=signs,
            )]
        all_targets += [ l(f) for f in 
            expand(
                f"{outdir}/rds_categ_metadata_{{d}}_{{e}}_{{p}}_{{s}}.json",
                d=datatypes,
                e=eventtypes_inclMC,
                p=polarities,
                s=signs,
            )]
        # ntuples with categorization and associated metadata
        # for samples without sign        
        all_targets += [ r(f) for f in 
            expand(
                f"{outdir}/rds_categ_{{d}}_{{e}}_{{p}}_None.root",
                d=datatypes,
                e=eventtypes,
                p=polarities,
            )]
        all_targets += [ l(f) for f in 
            expand(
                f"{outdir}/rds_categ_metadata_{{d}}_{{e}}_{{p}}_None.json",
                d=datatypes,
                e=eventtypes,
                p=polarities,
            )]

        # They are only needed to produce the other targets
        # Filtered ntuples for event type without sign
        all_targets += [ r(f) for f in 
            expand(
                f"{outdir}/rds_final_{{d}}_{{e}}_{{p}}_None.root",
                d=datatypes,
                e=eventtypes,
                p=polarities)]
        #Filtered ntuples for event type with RS/WS 
        all_targets += [ r(f) for f in 
            expand(
                f"{outdir}/rds_final_{{d}}_{{e}}_{{p}}_{{s}}.root",
                d=datatypes,
                e=eventtypes_sign,
                p=polarities,
                s=signs,
        )]
        all_targets += [r(f) for f in
            expand(f"{outdir}/rds_finalnoBYsep_2012_23903000_{{p}}_rs.root", p=polarities) ]
        all_targets += [r(f) for f in
            expand(f"{outdir}/rds_finalBMsup5000_2012_23903000_{{p}}_rs.root", p=polarities) ]

        all_targets += [r(f) for f in
            expand(f"{outdir}/rds_finalnoBYsep_2012_13266069_{{p}}_None.root", p=polarities) ]

        return all_targets

#rule signal:
