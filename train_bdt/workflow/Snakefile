rule export_histogram:
    input:
        script="workflow/scripts/export_histograms.py",
        deps=("workflow/scripts/data.py", "workflow/scripts/bdt_all.py"),
        data=bdt_input_files,
        bdt=local(f"{outdir}/bdt_all_200.pkl"),
    output:
        report=remote(f"{outdir}/templates/Template_{{cut}}_Cat{{categories}}.root"),
    log:
        "logs/Template{{cut}}Cat{{categories}}.log",
    shell:
        "python {input.script} {wildcards.cut} {wildcards.categories} {output} 2>&1 | tee {log}"


def needed_templates(w):
    groups = config['template_groups'][w.cut]
    group_names = []
    from collections.abc import Iterable
    for group in groups:
        if isinstance(group, Iterable):
            group_names.append("_".join([str(c) for c in group]))
        else:
            group_names.append(str(group))
    return [ remote(f"{outdir}/templates/Template_{{cut}}_Cat{g}.root") for g in group_names ]

rule merge_templates:
    input:
        needed_templates
    output:
        remote(f"{outdir}/templates/Templates_{{cut}}.root"),
    log:
        "logs/Template_{cut}_merge.log",
    shell:
        "echo hadd -f {output} {input};"
        "hadd -f {output} {input} 2>&1 | tee {log}"


rule export_category_fractions:
    input:
        script="workflow/scripts/export_category_fractions.py",
        deps=("workflow/scripts/data.py", "workflow/scripts/bdt_all.py"),
        data=bdt_input_files,
        bdt=local(f"{outdir}/bdt_all_200.pkl"),
    output:
        report=local(f"{outdir}/templates/category_fractions_{{cut}}.json"),
    log:
        "logs/category_fractions_{cut}.log",
    shell:
        "python {input.script} {wildcards.cut}  {output} 2>&1 | tee {log}"

