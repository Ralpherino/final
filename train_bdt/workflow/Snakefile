rule train_bdt_by_category_notebook:
    input:
        notebook="notebooks/train-bdt-by-category.ipynb",
        data=bdt_input_files
    output:
        pdf=local(f"{outdir}/train-bdt-by-category.pdf"),
    log:
        "logs/train-bdt-by-category_notebook.log",
    shell:
        "workflow/scripts/nbconvert.sh {input.notebook} {output.pdf} "
    
rule train_bdt_by_category:
    input:
        script="workflow/scripts/train_bdt_by_category.py",
        dep="workflow/scripts/data.py",
        data=bdt_input_files
    output:
        report=local(f"{outdir}/training_report_{{category}}_{{nbest}}.pdf"),
        model=local(f"{outdir}/categbdt_{{category}}_{{nbest}}.pkl"),
    log:
        "logs/train_bdt_by_category_{category}_{nbest}.log",
    shell:
        "echo {output};"
        "python {input.script} --eventIndex 0 --nb-estimators {wildcards.nbest} {wildcards.category} {output.report} {output.model} 2>&1 | tee {log}"

rule train_bdt_all:
    input:
        script="workflow/scripts/train_bdt_all.py",
        dep1="workflow/scripts/data.py",
        dep2="workflow/scripts/utils.py",
        data=bdt_input_files
    output:
        report=local(f"{outdir}/training_report_all_{{nbest}}.pdf"),
        model=local(f"{outdir}/bdt_all_{{nbest}}.pkl"),
    log:
        "logs/train_bdt_all_{nbest}.log",
    shell:
        "echo {output};"
        "python {input.script} --eventIndex 0 --nb-estimators {wildcards.nbest} {output.report} {output.model} 2>&1 | tee {log}"

rule train_bdtdblcharm:
    input:
        script="workflow/scripts/train_bdtdblcharm.py",
        dep1="workflow/scripts/data.py",
        dep2="workflow/scripts/utils.py",
        data=bdt_input_files
    output:
        report=remote(f"{outdir}/training_report_bdtdblcharm_{{n_estimators}}_{{max_depth}}_{{eta}}.pdf"),
        model=remote(f"{outdir}/bdtdblcharm_{{n_estimators}}_{{max_depth}}_{{eta}}.pkl"),
    log:
        "logs/train_bdtdblcharm_{n_estimators}_{max_depth}_{eta}.log",
    shell:
        "python {input.script} --nb-estimators {wildcards.n_estimators} --eta {wildcards.eta} --max-depth {wildcards.max_depth} training_report_bdtdblcharm_{wildcards.n_estimators}_{wildcards.max_depth}_{wildcards.eta}.pdf  bdtdblcharm_{wildcards.n_estimators}_{wildcards.max_depth}_{wildcards.eta}.pkl 2>&1 | tee {log};"
        "xrdcp  training_report_bdtdblcharm_{wildcards.n_estimators}_{wildcards.max_depth}_{wildcards.eta}.pdf {output.report};"
        "xrdcp  bdtdblcharm_{wildcards.n_estimators}_{wildcards.max_depth}_{wildcards.eta}.pkl {output.model};"

