#10 different templates grouping the categories as follows: 
#  [18],[29],[23],[15,0,others],[16,14],[25,7,19,13],[27,22],[20],[26],[21]

def bdt_input_files(w):
    return [
        remote(f"{datadir}/rds_categfiltered_2012_{eventtype}_{polarity}_rs_{str(category)}.root")
        for eventtype in ["23903000", "23903003"]
        for polarity in polarities
        for category in [18, 19, 20]
    ] + [
        remote(f"{datadir}/rds_categ_2012_13563002_{polarity}_rs.root")
        for polarity in polarities
    ]


rule check_variables:
    input:
        notebook="notebooks/Check_variables.ipynb",
        data=bdt_input_files
    output:
        pdf=local(f"{outdir}/Check_variables.pdf"),
    log:
        "logs/Check_variable.log",
    shell:
        "echo workflow/scripts/nbconvert.sh {input.notebook} {output.pdf}; "
        "workflow/scripts/nbconvert.sh {input.notebook} {output.pdf} "
    
rule train_bdt:
    input:
        notebook="notebooks/train-bdt.ipynb",
        data=bdt_input_files
    output:
        pdf=local(f"{outdir}/train-bdt.pdf"),
    log:
        "logs/train-bdt.log",
    shell:
        "workflow/scripts/nbconvert.sh {input.notebook} {output.pdf} "
    
